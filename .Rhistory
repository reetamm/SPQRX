dataset$lat <- coords[,2]
y <- matrix ( dataset$price, ncol = 1)
y <- y
dataset <- dataset[, names(dataset) != "price"]
x <- as.matrix(dataset[, c('bedrooms', 'bathrooms', 'squareFeet', 'lon', 'lat')])
data <- preprocessing.data(x, y)
data <- preprocessing_data(x, y)
