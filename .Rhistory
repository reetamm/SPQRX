as.data.frame() %>%
tibble::rownames_to_column("case") %>%
pivot_longer(
cols = -case,
names_to = "feature",
values_to = "feature_weight"
)
# Plot
ggplot(shap_result, aes(x = feature_weight, y = feature)) +
geom_jitter(height = 0.2, alpha = 0.6, size = 1.5) +
labs(
x = "SHAP Contribution",
y = "Feature",
title = "SHAP Summary Plot"
) +
theme_minimal()
